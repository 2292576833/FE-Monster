<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="#241B0D" />
            <stroke android:width="1dp" android:color="#C6A15B" />
            <corners android:radius="8dp" />
            <padding android:left="14dp" android:top="10dp" android:right="14dp" android:bottom="10dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#090806" />
            <stroke android:width="1dp" android:color="#80602B" />
            <corners android:radius="8dp" />
            <padding android:left="14dp" android:top="10dp" android:right="14dp" android:bottom="10dp" />
        </shape>
    </item>
</selector>
